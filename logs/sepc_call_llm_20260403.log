ToolMessage(content='{"object_name": "_check_and_remove_tool_calls", "source_code": "def _check_and_remove_tool_calls(tool_name, messages):\\n    while True:\\n        index = _get_first_tool_call(tool_name, messages)\\n        if index is not None:\\n            # 移除 tool call 和 tool message\\n            # TODO ，后续在考虑对tool_call_id进行校验\\n            messages.pop(index)       # tool call\\n            messages.pop(index)       # tool message (after deletion, same index)\\n        else:\\n            break\\n    return messages\\n"}', name='get_python_object_code', id='c0196aca-9a1d-4091-aee1-edff99d1bffd', tool_call_id='call_00_jWHWtsg21XBjCcIQ4GDPfJgd')

