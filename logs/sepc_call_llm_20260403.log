ToolMessage(content='{"object_name": "model_call_middleware", "source_code": "def model_call_middleware(context:object):\\n    \\n    @wrap_model_call\\n    async def modify_model_call(request, handler):\\n        \\"\\"\\"Middleware to modify model calls to fix tool_calls format in responses.\\"\\"\\"\\n        request = _filter_request(request)\\n        response = await handler(request)\\n        return response\\n\\n    return modify_model_call\\n"}', name='get_python_object_code', id='401fae6c-139e-4775-9679-067fadc5e531', tool_call_id='call_00_fZaqMEXWgbi5LSnD7NweukO9')

