ToolMessage(content='{"object_name": "sub_agent_check_point_reader", "source_code": "def sub_agent_check_point_reader(angent_name:str):\\n\\n    if not angent_name:\\n        raise ValueError(\\"angent_name is empty\\")\\n    thread_id = f\\"subagent_{angent_name}\\"\\n\\n    tup = check_point_reader(thread_id)\\n\\n    system_prompt = tup.metadata.get(\\"system_prompt\\", None)\\n    \\n    chat_records = [{\\n        \\"role\\" : \\"system\\",\\n        \\"content\\": system_prompt\\n    }]\\n\\n    messages = tup[1][\'channel_values\'][\'messages\']\\n    \\n    for m in messages:\\n        if isinstance(m, HumanMessage):\\n            chat_records.append({\\n                \\"role\\": \\"user\\",\\n                \\"content\\": m.content\\n            })\\n        elif isinstance(m, AIMessage):\\n\\n            conent_blocks = m.content_blocks\\n            contents = []\\n\\n            for block in conent_blocks:\\n                if block[\'type\'] == \'text\':\\n                    contents.append({\\n                        \\"type\\": \\"text\\",\\n                        \\"text\\": block[\'text\']\\n                    })\\n                elif block[\'type\'] == \'tool_call\':\\n                    contents.append({\\n                        \\"type\\": \\"tool_call\\",\\n                        \\"tool_name\\": block[\'name\'],\\n                        \\"tool_input\\": block[\'args\']\\n                    })\\n\\n            chat_records.append({\\n                \\"role\\": \\"assistant\\",\\n                \\"content\\": contents\\n\\n            })\\n        elif isinstance(m, ToolMessage):\\n            chat_records.append({\\n                \\"role\\": \\"tool\\",\\n                \\"name\\": m.name,\\n                \\"content\\": m.text\\n            })\\n\\n    return chat_records\\n"}', name='get_python_object_code', id='fab07f3e-69b3-4e37-9d88-b8dcac5d463d', tool_call_id='call_00_wv0BsFaF7kR2SWOP6ihklDGP')

