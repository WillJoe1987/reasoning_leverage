ToolMessage(content='{"object_name": "_get_first_tool_call", "source_code": "def _get_first_tool_call(tool_name, messages):\\n    # 基于OPENAI的协议，所以，toolcall和toolmessage是严格配对的；\\n    # 所以，这里就简化一下逻辑吧，不在搞什么复杂的栈结构了；\\n    for msg in reversed(messages):\\n        if isinstance(msg, ToolMessage) and msg.name == tool_name:\\n            index = indexOf(messages, msg)\\n            pre_msg = messages[index - 1] if index > 0 else None\\n            if not _check_tool_call_args(pre_msg):\\n                continue\\n            if index > 0:\\n                return index - 1\\n    return None\\n"}', name='get_python_object_code', id='7fdb6aab-4eb2-4feb-8f5b-2e2279a33de2', tool_call_id='call_00_dW4ZOYzVZc7eagiAisE7mwuO')

