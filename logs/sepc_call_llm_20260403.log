ToolMessage(content='{"object_name": "get_from_context", "source_code": "def get_from_context(context, key, default=None):\\n    \\"\\"\\"\\n    从 context 中获取指定 key 的值，支持多层嵌套访问。\\n    \\"\\"\\"\\n\\n    inject_context = getattr(context, \\"inject_context\\", None)\\n    if inject_context is not None:\\n        value = _get_from_context(inject_context, key, None)\\n        if value is not None:\\n            return value\\n    return _get_from_context(context, key, default)\\n"}', name='get_python_object_code', id='06a3a489-d9bc-44fb-bc5d-b8bd86244f46', tool_call_id='call_00_QW5a8U1kUA0MUXStn2B7BSBh')

